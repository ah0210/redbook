{
  "name": "@lucasygu/redbook",
  "version": "0.1.10",
  "description": "CLI tool for Xiaohongshu (Red Note) - read and post via private API",
  "type": "module",
  "main": "./dist/lib/client.js",
  "exports": {
    ".": "./dist/lib/client.js",
    "./cookies": "./dist/lib/cookies.js",
    "./signing": "./dist/lib/signing.js"
  },
  "bin": {
    "redbook": "dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "SKILL.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "xiaohongshu",
    "redbook",
    "xhs",
    "red-note",
    "cli",
    "claude-code",
    "claude-code-skill"
  ],
  "author": "lucasygu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasygu/redbook.git"
  },
  "bugs": {
    "url": "https://github.com/lucasygu/redbook/issues"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "^0.1.0",
    "commander": "^13.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
