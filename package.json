{
  "name": "redbook",
  "version": "0.1.0",
  "description": "CLI tool for Xiaohongshu (Red Note) - read and post via private API",
  "type": "module",
  "main": "./dist/lib/client.js",
  "bin": {
    "redbook": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "xiaohongshu",
    "redbook",
    "xhs",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@steipete/sweet-cookie": "^0.1.0",
    "commander": "^13.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
